---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Privacy Policy | Stack and Sleep</title>
  <meta name="description" content="Stack and Sleep privacy policy — how we collect, use, and protect your data." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://stackandsleep.com/privacy-policy/" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/src/styles/global.css" />
  <link rel="stylesheet" href="/src/styles/nav.css" />
  <link rel="stylesheet" href="/src/styles/cards.css" />
  <link rel="stylesheet" href="/src/styles/article.css" />
</head>
<body class="article-page">

  <div class="disclosure-bar">
    Independent reviews — affiliate links at no extra cost to you.&nbsp;
    <a href="/affiliate-disclosure/">Full disclosure</a>&nbsp;·&nbsp;
    <a href="/how-we-review/">How we review</a>
  </div>

  <Nav />

  <main>
    <header class="article-header">
      <div class="article-header-cat">Legal</div>
      <h1>Privacy Policy</h1>
      <div class="article-header-meta">
        <span>Last updated: April 2026</span>
      </div>
    </header>

    <div class="article-body">
      <!--
        OWNER ACTION REQUIRED:
        Generate your full privacy policy at https://www.termsfeed.com/privacy-policy-generator/
        (free tier is sufficient for a basic affiliate site)
        Paste the generated Markdown/HTML content here, replacing this placeholder block.
        Make sure to include:
        - What data you collect (email addresses via the sign-up form)
        - How you use it (email newsletter)
        - Third-party services (Airtable, Vercel, Amazon Associates, Google Analytics if used)
        - Cookie policy
        - User rights (access, deletion, unsubscribe)
        - Contact information
      -->
      <p><em>This privacy policy is a placeholder. The site owner will replace this with a complete policy generated via <a href="https://www.termsfeed.com" target="_blank" rel="noopener">TermsFeed.com</a> before launch.</em></p>

      <h2>What we collect</h2>
      <p>We collect email addresses when you voluntarily subscribe to our newsletter via the sign-up form on this site. We do not collect any other personal data.</p>

      <h2>How we use your data</h2>
      <p>Your email address is used solely to send our newsletter. We do not sell, rent, or share your email address with third parties.</p>

      <h2>Third-party services</h2>
      <p>This site uses Airtable to store subscriber email addresses, and Vercel to host the website. Both services have their own privacy policies.</p>

      <h2>Cookies</h2>
      <p>This site does not currently use cookies beyond those set by affiliate networks when you click product links.</p>

      <h2>Your rights</h2>
      <p>You can unsubscribe from our newsletter at any time using the unsubscribe link in any email we send. To request deletion of your data, <a href="/contact/">contact us</a>.</p>

      <h2>Contact</h2>
      <p>For privacy enquiries, please use our <a href="/contact/">contact form</a>.</p>
    </div>
  </main>

  <Footer />
</body>
</html>
