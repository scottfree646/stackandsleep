---
const { href, label = 'Check price on Amazon →' } = Astro.props
---
<a
  href={href}
  target="_blank"
  rel="nofollow noopener sponsored"
  class="affiliate-btn"
>
  {label}
</a>

<style>
.affiliate-btn {
  display: inline-block;
  background: #e8622a;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  padding: 11px 24px;
  border-radius: 8px;
  text-decoration: none;
  letter-spacing: 0.02em;
  margin: 12px 0 20px;
  transition: background 0.2s;
}
.affiliate-btn:hover {
  background: #c4521f;
}
</style>
