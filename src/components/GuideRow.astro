---
interface Props {
  num: string;
  category: string;
  title: string;
  description: string;
  slug: string;
}
const { num, category, title, description, slug } = Astro.props;
---
<a href={`/articles/${slug}/`} class="guide-row">
  <div class="guide-num">{num}</div>
  <div class="guide-info">
    <div class="guide-cat">{category}</div>
    <h4>{title}</h4>
    <p>{description}</p>
  </div>
</a>
