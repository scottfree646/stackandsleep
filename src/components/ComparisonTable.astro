---
interface Props {
  headers: string[];
  rows: string[][];
}
const { headers, rows } = Astro.props;
---
<div class="comparison-table-wrap">
  <table class="comparison-table">
    <thead>
      <tr>
        {headers.map(h => <th>{h}</th>)}
      </tr>
    </thead>
    <tbody>
      {rows.map(row => (
        <tr>
          {row.map(cell => <td>{cell}</td>)}
        </tr>
      ))}
    </tbody>
  </table>
</div>
